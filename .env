# Ghost-Shell Chess Configuration

# Engine Settings
ENGINE_DEPTH=15
ENGINE_CONTEMPT=20

# Human mistakes: occasionally play a small inaccuracy (never a losing blunder).
# MISTAKE_CHANCE=0 plays best every time. MAX_DROP is centipawns worse allowed (100=1 pawn).
# FLOOR is the lowest eval (cp) a mistake may leave you at, so you never go into a loss.
MISTAKE_CHANCE=0.15
MISTAKE_MAX_DROP=110
MISTAKE_FLOOR=-100

# Humanization
MOUSE_SPEED=0.4
TARGET_JITTER=6

# Thinking Time (seconds) - randomized between min and max
THINK_TIME_MIN=1.5
THINK_TIME_MAX=6.0

# Side Detection: AUTO, WHITE, BLACK
PLAYER_SIDE=AUTO

# Move execution mode.
# USE_BROWSER=true  -> bot launches a Playwright browser and clicks moves via CDP
#                      (no hardware mouse, terminal keeps focus). Keep that browser
#                      window visible on screen so vision can still read the board.
# USE_BROWSER=false -> legacy mode: drives your real mouse with pyautogui.
USE_BROWSER=true
CHESS_URL=https://www.chess.com
# Browser to launch: "chrome" (real Google Chrome, needed for chess.com's bot
# engines) or "msedge". Leave blank for Playwright's bundled Chromium.
BROWSER_CHANNEL=chrome
# Chrome is launched detached on this debug port and the bot connects over CDP, so
# Chrome stays open after the bot exits (you close it yourself) and restarts reconnect.
CDP_PORT=9222
# Optional explicit path to the browser .exe (blank = auto-detect Chrome/Edge).
CHROME_PATH=

# Startup defaults
# QUICK_START=true skips the FEN/new-game question and uses the defaults below.
QUICK_START=false
DEFAULT_GAME_MODE=RAPID
DEFAULT_START_MODE=N
PAUSE_ON_EXIT=true
